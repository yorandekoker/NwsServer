<section class="hero">
    <span class="hero__badge">Tech Nieuws</span>
    <h2>Laatste Nieuws</h2>
    <p>Blijf op de hoogte van het laatste tech-nieuws</p>
    <a href="/add" class="hero__add-btn">+ Artikel toevoegen</a>
</section>

<ul class="news-list">
    <% news.forEach((article, index) => { %>
        <li class="news-item">
            <% if (article.image) { %>
                <img src="<%= article.image %>" alt="<%= article.title %>" class="news-item__image">
            <% } else { %>
                <span class="news-item__number"><%= String(index + 1).padStart(2, '0') %></span>
            <% } %>
            <div class="news-item__content">
                <h3 class="news-item__title"><%= article.title %></h3>
                <p class="news-item__desc"><%= article.content %></p>
            </div>
            <a href="/<%= article.slug %>" class="news-item__link" aria-label="Lees meer over <%= article.title %>">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
        </li>
    <% }); %>
</ul>